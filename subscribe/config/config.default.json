{
    "domains": [],
    "crawl": {
        "enable": true,
        "threshold": 0,
        "singlelink": true,
        "config": {
            "liveness": false,
            "include": "香港|美国|日本|台湾",
            "exclude": "过期|重置",
            "rename": "Ultimate_Node"
        },
        "pages": [
            { "enable": true, "url": "https://gh-proxy.com/raw.githubusercontent.com/Barabama/FreeNodes/main/nodes/nodev2ray.yaml", "push_to": ["ultimate-clash"] },
            { "enable": true, "url": "https://raw.githubusercontent.com/mahdibland/ShadowsocksAggregator/master/Eternity.yml", "push_to": ["ultimate-clash"] },
            { "enable": true, "url": "https://tt.vg/freeclash", "push_to": ["ultimate-clash"] }
        ]
    },
    "groups": {
        "ultimate-clash": {
            "emoji": true,
            "list": true,
            "targets": {
                "clash": "Ultimate_Speed_Fixed"
            }
        }
    },
    "storage": {
        "engine": "github",
        "items": {
            "ultimate-clash": {
                "username": "zlong361",
                "repo": "aggregator",
                "branch": "output",
                "path": "clash.yaml"
            }
        }
    }
}
